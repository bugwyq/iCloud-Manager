# iCloud-Manager environment
# Copy this file to .env and adjust values for your deployment.

# Panel login password. Change this before deploying.
ICLOUD_PANEL_PASSWORD=changeme

# Bind the app to localhost when using an HTTPS reverse proxy.
APP_BIND=127.0.0.1
APP_PORT=17607

# Public URL used when exporting /show links.
# Example: http://192.220.23.97:17607 or https://your-domain
# If empty, exported links default to http://127.0.0.1:17607
ICLOUD_PUBLIC_BASE_URL=https://your-domain

# Optional access token for exported /show links.
# If set, exported links include ?key=...
# ICLOUD_VIEWER_TOKEN=

# Scan and IMAP fetch tuning.
# ICLOUD_SCAN_WORKERS=5
# ICLOUD_FETCH_TIMEOUT=25
# ICLOUD_FETCH_RETRIES=4
# ICLOUD_RETRY_DELAY=30
# ICLOUD_MAX_RETRY_PASSES=3
